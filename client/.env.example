# =============================================
# DairyOS Pro - Client Environment Variables
# =============================================
# Copy this file to .env and fill in the values.
# NEVER commit the actual .env file!

# ------ API Configuration ------
# For LOCAL development (default):
VITE_API_URL=http://localhost:5000/api

# For PRODUCTION on Vercel, set this to your Render backend URL:
# VITE_API_URL=https://dairyospro-server.onrender.com/api

# ------ Firebase (currently unused — auth uses email/password) ------
# If re-enabling Firebase OTP in future, set these values:
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_MEASUREMENT_ID=
